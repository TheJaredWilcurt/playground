    "cssnano": "^8.0.2",
    "cssnano-preset-advanced": "^8.0.2",
    "csso": "^5.0.5",
    "esbuild-wasm": "^0.28.1",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "lightningcss-wasm": "^1.33.0",
    "normalize.css": "^8.0.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.21",
    "pretty-ms": "^9.3.0",
    "sass": "^1.101.3",
    "string_decoder": "^1.3.0",
