{
  "name": "playground",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && vite preview --port 4173",
    "test": "cross-env TZ=America/New_York vitest run --coverage",
    "unit": "cross-env TZ=America/New_York vitest --coverage",
    "lint": "eslint --ext .js,.vue src tests vite.config.js eslint.config.js",
    "fix": "npm run lint -- --fix",
    "proto": "proto pin node latest --resolve --tool-native && git status"
  },
  "ManifestComments": [],
  "dependencies": {
    "@sarap422/font-dinish": "^1.0.6",
    "@thejaredwilcurt/csslop": "^0.0.16",
    "clean-css": "^5.3.3",
    "csskit": "^0.0.28-canary.eddaa0a071",
    "csso": "^5.0.5",
    "fflate": "^0.8.3",
    "normalize.css": "^8.0.1",
    "sass": "^1.101.0",
    "vue": "^3.5.40",
    "vue-options-api-constants-plugin": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-tjw-base": "^5.0.0",
    "eslint-config-tjw-import-x": "^1.0.1",
    "eslint-config-tjw-jest": "^4.0.0",
    "eslint-config-tjw-vue": "^4.0.0",
    "eslint-import-resolver-vite": "^2.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-vue": "^10.10.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "vite": "^8.1.5",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.0",
    "vue3-snapshot-serializer": "^2.13.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "allowScripts": {
    "@parcel/watcher@2.6.0": true,
    "unrs-resolver@1.12.2": true
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.5.0"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.17.0"
    }
  }
}
